# Clerk publishable key (client-safe). Set this to turn on login + per-org
# (tenant) isolation. Leave it unset to run the no-login, single-default-tenant
# demo. Copy to `.env` (gitignored) and fill in your key from the Clerk dashboard.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Optional: point the frontend at a deployed backend (defaults to the Vite proxy
# → http://localhost:8000). e.g. https://eligo-api.up.railway.app/api/v1
# VITE_API_BASE_URL=
