# ---------------------------------------------------------------------------
# eligo-tech backend — example configuration.
# Copy to `.env` and adjust. The scaffold RUNS with these defaults and needs
# NO external services (SQLite fallback).
# ---------------------------------------------------------------------------

# App
ELIGO_APP_NAME="eligo-tech"
ELIGO_ENV=local
ELIGO_DEBUG=true

# Database
# Default: file-backed SQLite (async). Zero external dependencies.
ELIGO_DATABASE_URL="sqlite+aiosqlite:///./eligo.db"
#
# Supabase (managed Postgres) — the production system-of-record.
# Use the async driver prefix (postgresql+asyncpg), your project's Session
# Pooler host, and URL-encode the password. NEVER commit the real password —
# put it in .env (gitignored), not here.
#   ELIGO_DATABASE_URL="postgresql+asyncpg://postgres.dcolbtxcszgrikcznomd:<PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
#   ELIGO_DB_SSL=true
# (Transaction pooler on :6543 also works — the app disables statement caching for it.)
# ELIGO_DB_SSL=false

# CORS — frontend origins allowed to call the API (comma-separated or JSON list)
ELIGO_CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Multi-tenancy — default tenant used by seed data / demo endpoints.
ELIGO_DEFAULT_TENANT_ID="00000000-0000-0000-0000-000000000001"

# LLM extraction (CV upload). Vendor-neutral: the factory selects an extractor
# by provider and always falls back to the heuristic parser if unavailable.
ELIGO_LLM_PROVIDER="openai"        # "openai" | "heuristic"
ELIGO_LLM_MODEL="gpt-4o-mini"
# The OpenAI extractor reads the STANDARD (unprefixed) OPENAI_API_KEY. Put the
# real key in .env (gitignored), never here. Absent → falls back to heuristic.
# OPENAI_API_KEY="sk-..."

# Matching/outreach LLM boundary is still stubbed (deterministic).